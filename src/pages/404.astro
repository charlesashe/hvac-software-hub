---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found — HVAC Software Hub"
  description="The page you're looking for doesn't exist."
  canonicalPath="/404"
>
  <section class="container py-24 text-center">
    <p class="text-6xl font-bold text-[var(--color-muted)]/30 mb-4" style="font-family: var(--font-heading);">404</p>
    <h1 class="font-bold text-2xl mb-3" style="font-family: var(--font-heading);">Page Not Found</h1>
    <p class="text-[var(--color-muted)] mb-8 max-w-md mx-auto">
      The page you are looking for does not exist or has been moved. Try one of our guides instead.
    </p>
    <a href="/" class="cta-button">Back to Home →</a>
  </section>
</Layout>
