<Layout
  title="HVAC Software Hub — Independent Software Reviews for Contractors"
  description="Independent reviews and comparisons of CRM, dispatch, scheduling, and call tracking software for HVAC and plumbing companies. Scored reviews with transparent methodology. No hype."
  canonicalPath="/"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={HERO_IMG} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/30"></div>
    </div>
    <div class="relative container py-20 md:py-28">
      <div class="max-w-2xl">
        <p class="data-label text-orange-300 mb-4">Independent Software Reviews for HVAC Contractors</p>
        <h1 class="font-bold text-3xl md:text-5xl text-white leading-tight mb-6" style="font-family: var(--font-heading);">
          Find the Right Software Stack for Your HVAC Business
        </h1>
        <p class="text-lg text-white/80 mb-8 leading-relaxed">
          We compare CRM, dispatch, scheduling, and call tracking tools so you can stop guessing and start growing. No hype. No fluff. Just scored reviews built for contractors.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/hvac/crm/best-crm-for-small-hvac-companies" class="cta-button">Read Our CRM Guide →</a>
          <a href="/lead-magnet" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 text-white border border-white/20 rounded-md font-medium text-sm hover:bg-white/20 transition-colors no-underline">Get Free Toolkit ↓</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="container py-16">
    <h2 class="font-semibold text-2xl mb-2" style="font-family: var(--font-heading);">Browse by Category</h2>
    <p class="text-[var(--color-muted)] mb-8">Every review is scored on a weighted framework built for HVAC businesses.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map((cat) => (
        <a href={cat.href} class="group border border-[var(--color-border)] rounded-lg p-5 bg-white hover:border-[var(--color-primary)]/30 hover:shadow-sm transition-all no-underline">
          <span class="text-2xl mb-3 block">{cat.icon}</span>
          <h3 class="font-semibold text-sm mb-1 text-[var(--color-foreground)] group-hover:text-[var(--color-primary)] transition-colors" style="font-family: var(--font-heading);">{cat.label}</h3>
          <p class="text-xs text-[var(--color-muted)]">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="container pb-16">
    <h2 class="font-semibold text-2xl mb-2" style="font-family: var(--font-heading);">Latest Guides</h2>
    <p class="text-[var(--color-muted)] mb-8">Published this month. Updated regularly.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {articles.map((article) => (
        <a href={`/hvac/${article.catSlug}/${article.slug}`} class="group border border-[var(--color-border)] rounded-lg bg-white overflow-hidden hover:border-[var(--color-primary)]/30 hover:shadow-sm transition-all no-underline">
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="data-label bg-[var(--color-accent)] px-2 py-0.5 rounded text-xs">{article.category}</span>
              <span class="data-label text-xs">{article.intent}</span>
            </div>
            <h3 class="font-semibold text-lg text-[var(--color-foreground)] group-hover:text-[var(--color-primary)] transition-colors mb-2" style="font-family: var(--font-heading);">{article.title}</h3>
            <p class="text-sm text-[var(--color-muted)] mb-3">{article.desc}</p>
            <div class="flex items-center gap-3 text-xs text-[var(--color-muted)]">
              <span>{article.readTime}</span>
              <span>&middot;</span>
              <span>{new Date(article.date).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Lead Magnet CTA -->
  <section class="bg-white border-t border-b border-[var(--color-border)]">
    <div class="container py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
