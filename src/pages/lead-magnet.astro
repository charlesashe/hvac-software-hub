const kitContents = [
  {
    title: "5-Stage CRM Pipeline Template",
    desc: "Map your customer journey from first call to repeat business. Copy this into Jobber, Housecall Pro, or any CRM.",
    items: ["New Lead → Estimate Sent → Estimate Approved → Job Scheduled → Job Complete"],
  },
  {
    title: "5 SMS Follow-Up Scripts",
    desc: "Copy-paste text messages for the five most common follow-up situations HVAC contractors face.",
    items: [
      "Post-estimate follow-up (same day)",
      "Estimate reminder (3 days, no response)",
      "Appointment confirmation (day before)",
      "Post-job review request",
      "Seasonal maintenance reminder",
    ],
  },
  {
    title: "Missed Call Recovery Checklist",
    desc: "A step-by-step process to recover revenue from missed calls. Most HVAC companies miss 20-30% of inbound calls.",
    items: [
      "Callback within 5 minutes (before they call a competitor)",
      "Text message if no answer",
      "Voicemail script template",
      "End-of-day missed call audit process",
    ],
  },
];
---

<Layout
  title="Free Contractor Follow-Up Kit — HVAC Software Hub"
  description="Download the free Contractor Follow-Up Kit: CRM pipeline template, SMS scripts, and missed call recovery checklist for HVAC companies."
  canonicalPath="/lead-magnet"
>
  <!-- Hero -->
  <section class="bg-white border-b border-[var(--color-border)]">
    <div class="container py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="data-label text-[var(--color-primary)] mb-3">Free Download — No Credit Card Required</p>
          <h1 class="font-bold text-3xl md:text-4xl leading-tight mb-4" style="font-family: var(--font-heading);">
            The Contractor Follow-Up Kit
          </h1>
          <p class="text-lg text-[var(--color-foreground)]/70 mb-6 leading-relaxed">
            Stop losing jobs to slow follow-up. This free toolkit gives you the exact pipeline, scripts, and checklists that top HVAC companies use to convert more estimates into booked jobs.
          </p>
          <div class="flex items-center gap-6 mb-8 text-sm text-[var(--color-muted)]">
            <span class="flex items-center gap-1">↓ 3-page PDF</span>
            <span class="flex items-center gap-1">✉ Instant delivery</span>
          </div>
          <form id="lead-form" class="space-y-3 max-w-sm">
            <input
              type="email"
              required
              placeholder="Your work email"
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 bg-white"
            />
            <select class="w-full px-4 py-3 border border-[var(--color-border)] rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 bg-white text-[var(--color-foreground)]/70">
              <option value="">Team size (optional)</option>
              <option value="1">Solo operator</option>
              <option value="2-5">2-5 technicians</option>
              <option value="6-10">6-10 technicians</option>
              <option value="10+">10+ technicians</option>
            </select>
            <button
              type="submit"
              class="w-full px-6 py-3 bg-[var(--color-primary)] text-white rounded-md font-medium text-sm hover:opacity-90 transition-colors flex items-center justify-center gap-2"
            >
              Get the Free Kit ↓
            </button>
            <p class="text-xs text-[var(--color-muted)]">
              No spam. Unsubscribe anytime. We will also send you our weekly HVAC software tips.
            </p>
          </form>
          <div id="success-msg" class="hidden bg-green-50 border border-green-200 rounded-lg p-6 max-w-sm">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-green-600 text-lg">✓</span>
              <span class="font-semibold text-green-800">Check your inbox!</span>
            </div>
            <p class="text-sm text-green-700">
              We have sent the Contractor Follow-Up Kit to your email. If you do not see it in 5 minutes, check your spam folder.
            </p>
          </div>
        </div>
        <div class="flex justify-center">
          <img
            src={LEAD_MAGNET_IMG}
            alt="Contractor Follow-Up Kit preview showing pipeline template and SMS scripts"
            class="w-80 md:w-96 rounded-lg shadow-lg"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What's Inside -->
  <section class="container py-16">
    <h2 class="font-semibold text-2xl mb-2" style="font-family: var(--font-heading);">What's Inside the Kit</h2>
    <p class="text-[var(--color-muted)] mb-8">Three tools you can implement today, regardless of which CRM you use.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {kitContents.map((section, i) => (
        <div class="border border-[var(--color-border)] rounded-lg p-6 bg-white">
          <div class="w-8 h-8 rounded bg-[var(--color-primary)]/10 flex items-center justify-center mb-4">
            <span class="text-[var(--color-primary)] font-mono font-bold text-sm">{i + 1}</span>
          </div>
          <h3 class="font-semibold text-lg mb-2" style="font-family: var(--font-heading);">{section.title}</h3>
          <p class="text-sm text-[var(--color-muted)] mb-4">{section.desc}</p>
          <ul class="space-y-1.5 list-none p-0">
            {section.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-[var(--color-foreground)]/80">
                <span class="text-[var(--color-primary)] mt-0.5 flex-shrink-0">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Social Proof -->
  <section class="bg-white border-t border-b border-[var(--color-border)]">
    <div class="container py-12 text-center">
      <p class="text-sm text-[var(--color-muted)] mb-4">Built from research across 50+ HVAC companies and 12 software platforms</p>
      <div class="flex justify-center gap-8 flex-wrap">
        <div>
          <p class="font-bold text-2xl text-[var(--color-foreground)]" style="font-family: var(--font-heading);">5</p>
          <p class="text-xs text-[var(--color-muted)]">Ready-to-use SMS scripts</p>
        </div>
        <div>
          <p class="font-bold text-2xl text-[var(--color-foreground)]" style="font-family: var(--font-heading);">20-30%</p>
          <p class="text-xs text-[var(--color-muted)]">Avg. missed call rate in HVAC</p>
        </div>
        <div>
          <p class="font-bold text-2xl text-[var(--color-foreground)]" style="font-family: var(--font-heading);">$500+</p>
          <p class="text-xs text-[var(--color-muted)]">Revenue recovered per missed call</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Content -->
  <section class="container py-12">
    <h2 class="font-semibold text-xl mb-6" style="font-family: var(--font-heading);">Want to go deeper? Read our guides:</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/hvac/crm/best-crm-for-small-hvac-companies" class="block border border-[var(--color-border)] rounded-lg p-5 bg-white hover:border-[var(--color-primary)]/30 transition-colors no-underline">
        <h3 class="font-semibold text-sm text-[var(--color-foreground)] mb-1" style="font-family: var(--font-heading);">Best CRM for Small HVAC Companies</h3>
        <p class="text-xs text-[var(--color-muted)]">Scored reviews of the top 5 CRMs for teams under 10 techs.</p>
      </a>
      <a href="/hvac/dispatch/best-dispatch-software-for-hvac" class="block border border-[var(--color-border)] rounded-lg p-5 bg-white hover:border-[var(--color-primary)]/30 transition-colors no-underline">
        <h3 class="font-semibold text-sm text-[var(--color-foreground)] mb-1" style="font-family: var(--font-heading);">Best Dispatch Software for HVAC</h3>
        <p class="text-xs text-[var(--color-muted)]">Find the right dispatch tool for your operation size.</p>
      </a>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('lead-form');
  const successMsg = document.getElementById('success-msg');
  if (form && successMsg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    });
  }
</script>
