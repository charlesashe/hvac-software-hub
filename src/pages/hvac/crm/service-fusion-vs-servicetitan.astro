const faqItems = [
  {
    q: "What's the real cost difference between Service Fusion and ServiceTitan?",
    a: "Service Fusion starts at $99/month for basic plans, while ServiceTitan typically runs $300-500+ per user monthly. For a 5-person team, you're looking at $495/month vs $1,500-2,500/month respectively."
  },
  {
    q: "Can Service Fusion handle the same job volume as ServiceTitan?",
    a: "Service Fusion works well for companies running 50-200 jobs monthly. ServiceTitan is built for 500+ jobs monthly. If you're processing over 300 jobs monthly, ServiceTitan's infrastructure provides better performance."
  },
  {
    q: "Which platform has better mobile apps for technicians?",
    a: "ServiceTitan's mobile app is more robust with offline capabilities and advanced inventory management. Service Fusion's app covers basics well but lacks some advanced features like photo annotations and complex job routing."
  },
  {
    q: "How long does implementation take for each platform?",
    a: "Service Fusion typically takes 2-4 weeks to implement fully. ServiceTitan requires 6-12 weeks due to its complexity and extensive customization options. Factor in additional training time for ServiceTitan."
  },
  {
    q: "Do both platforms integrate with QuickBooks?",
    a: "Yes, both offer QuickBooks integration, but ServiceTitan provides deeper financial reporting and more automated sync options. Service Fusion's integration covers basic invoicing and payment syncing."
  }
];
