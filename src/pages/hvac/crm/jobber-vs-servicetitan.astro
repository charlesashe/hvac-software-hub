  <td>Not included</td>
  <td>Not included (integrates w/ CallRail)</td>
  <td>Tie</td>
</tr>
<tr>
  <td>Mobile App</td>
  <td>Clean, fast</td>
  <td>Feature-rich, heavier</td>
  <td>Jobber (simplicity)</td>
</tr>
