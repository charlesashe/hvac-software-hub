---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: "fit-score", label: "HVAC CRM Fit Score" },
  { id: "quick-pick", label: "Quick Pick Table" },
  { id: "jobber", label: "1. Jobber" },
  { id: "workiz", label: "2. Workiz" },
  { id: "servicetitan", label: "3. ServiceTitan" },
  { id: "service-fusion", label: "4. Service Fusion" },
  { id: "decision-tree", label: "How to Choose" },
  { id: "faq", label: "FAQ" },
  { id: "summary", label: "Summary" }
];
const faqItems = [
  { q: "Do I need a CRM if I have fewer than 5 technicians?", a: "Yes. Even with 1-2 techs, a CRM pays for itself by preventing lost leads and saving administrative time. A simple CRM like Jobber Core ($39/mo) can centralize your customer data, automate appointment reminders, and make you look more professional." },
  { q: "How long does setup take?", a: "It varies by platform. Jobber can be operational in 1-3 days. Workiz might take 1-2 weeks. ServiceTitan requires a 4-12 week implementation project. Our Ease of Use score reflects this setup time." },
  { q: "Can I switch CRMs without losing my customer data?", a: "Yes. All major CRMs offer data import via CSV files. You can export your customer list, job history, and price book from your old system and import it into the new one. Most platforms offer support for this process." },
  { q: "What integrations matter most for an HVAC company?", a: "The most critical integration is QuickBooks (Online or Desktop). Other important integrations include call tracking (CallRail), review platforms (Google, NiceJob, Birdeye), and payment processors (Stripe or Square)." },
  { q: "What is the real cost, including add-ons?", a: "For a small team (3 users), expect $150-250/mo for a mid-tier plan like Jobber Connect or Workiz Standard. Flat-rate plans like Service Fusion have higher starting prices but no per-user fees. Always confirm which features are included in each tier." },
  { q: "What if I outgrow my CRM?", a: "If you start with Jobber and grow to 10+ technicians, you can migrate to ServiceTitan when the time is right. All tools allow data export. Start with the tool that fits your business today." }
];
