  { id: 'tools-that-pair', label: 'Tools That Pair Well' },
  { id: 'decision-framework', label: 'Choosing the Right Tool' }
];

const faqItems = [
  {
    q: "How much time can HVAC estimating software save per quote?",
    a: "Professional estimating software reduces quote creation time by 65-80%. Manual quotes that take 45-60 minutes can be completed in 8-12 minutes with the right software. For contractors creating 20+ quotes weekly, this translates to 12-16 hours saved per week."
  },
  {
    q: "What's the average cost of HVAC estimating software in 2026?",
    a: "Standalone estimating tools range from $89-$299 per month. All-in-one platforms with integrated estimating start at $129/month for basic plans. Enterprise solutions can cost $400-$800+ monthly but include advanced features like automated material pricing updates and multi-location support."
  },
  {
    q: "Do I need separate software for estimates and invoicing?",
    a: "Not necessarily. Modern platforms like Jobber and Housecall Pro handle estimates, invoicing, scheduling, and customer management in one system. This integration prevents double data entry and ensures quote-to-cash accuracy. Standalone estimating tools require separate invoicing software."
  },
  {
    q: "How accurate are automated material pricing updates?",
    a: "Leading software providers update material costs weekly or bi-weekly from major distributors. Accuracy rates are typically 95-98% for standard HVAC components. However, contractors should verify pricing for specialized equipment or during volatile market periods."
  },
  {
    q: "Can estimating software integrate with my existing accounting system?",
    a: "Most professional HVAC estimating tools integrate with QuickBooks, Sage, and other accounting platforms. Integration typically costs $20-$50 monthly extra but eliminates manual data entry and ensures financial accuracy. Check integration capabilities before purchasing."
  }
];
