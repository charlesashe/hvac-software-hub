            <td style="padding:10px;">Basic (Price Book add-on $149/mo)</td>
          </tr>
          <tr style="background:#f8f9fa;">
            <td style="padding:10px;">Marketing attribution</td>
            <td style="padding:10px;">Marketing Pro ($2,000+/mo) ties ad spend to revenue</td>
