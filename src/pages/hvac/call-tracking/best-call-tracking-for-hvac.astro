---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: "why-call-tracking", label: "Why Call Tracking Matters" },
  { id: "quick-pick", label: "Quick Pick Table" },
  { id: "callrail", label: "1. CallRail" },
  { id: "calltrackingmetrics", label: "2. CallTrackingMetrics" },
  { id: "workiz", label: "3. Workiz (Built-In)" },
  { id: "whatconverts", label: "4. WhatConverts" },
  { id: "marchex", label: "5. Marchex" },
  { id: "pricing", label: "Pricing Comparison" },
  { id: "how-to-choose", label: "How to Choose" },
  { id: "faq", label: "FAQ" }
];
const faqItems = [
  { q: "Do I need call tracking if I already have a CRM like Jobber?", a: "Yes. Jobber, Housecall Pro, and most CRMs do not track which marketing channel generated each inbound call. Call tracking fills that gap by assigning unique phone numbers to each source (Google Ads, LSA, organic, etc.) so you know exactly where your leads come from." },
  { q: "Will call tracking numbers hurt my local SEO?", a: "Not if set up correctly. Use dynamic number insertion (DNI) on your website so Google still sees your real business number in structured data. Only swap the displayed number for visitors. All top call tracking platforms support this." },
  { q: "What is the minimum budget for call tracking?", a: "CallRail starts at $50/month for 5 local numbers and 250 minutes. For a small HVAC company running Google Ads and LSA, budget $50-100/month for call tracking. The ROI typically pays for itself by identifying one wasted ad channel." },
  { q: "Can I integrate call tracking with my field service software?", a: "Yes. CallRail integrates with Housecall Pro, Jobber, and ServiceTitan. CallTrackingMetrics integrates with most CRMs via Zapier. Workiz has call tracking built in, so no integration is needed." },
  { q: "What is dynamic number insertion (DNI)?", a: "DNI automatically swaps the phone number displayed on your website based on how the visitor arrived (Google Ads, organic search, Facebook, direct, etc.). This lets you track which marketing channels drive phone calls without maintaining separate landing pages." }
];
