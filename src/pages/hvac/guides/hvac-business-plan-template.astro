import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: 'executive-summary', label: 'Executive Summary' },
  { id: 'market-analysis', label: 'Market Analysis' },
  { id: 'services-pricing', label: 'Services & Pricing Strategy' },
  { id: 'financial-projections', label: 'Financial Projections' },
  { id: 'operations-plan', label: 'Operations Plan' },
  { id: 'marketing-strategy', label: 'Marketing Strategy' },
  { id: 'management-team', label: 'Management Team' },
  { id: 'funding-request', label: 'Funding Request' },
  { id: 'common-mistakes', label: 'Common Mistakes to Avoid' }
];

const faqItems = [
  {
    q: "How much funding do I need to start an HVAC company?",
    a: "Most HVAC startups need $50,000-$150,000 in initial funding. This covers a service van ($25,000-$40,000), tools and equipment ($15,000-$25,000), initial inventory ($10,000-$20,000), insurance and bonding ($8,000-$15,000), and 3-6 months of operating expenses ($20,000-$50,000)."
  },
  {
    q: "What financial metrics do lenders focus on for HVAC businesses?",
    a: "Lenders prioritize gross margins (target 50-65%), customer acquisition cost ($150-$300 per customer), average job size ($350-$500 for service, $4,000-$12,000 for installs), and seasonal cash flow patterns. They also want to see 12-18 months of projected cash flow statements."
  },
  {
    q: "How do I project revenue for my first year?",
    a: "Start with your service area population, identify your target market (typically 20-30% of households), estimate market penetration (0.5-2% in year one), and multiply by average job frequency (1.2-2.4 calls per year) and average ticket size. Include seasonal adjustments (40% higher revenue in summer months)."
  },
  {
    q: "What licenses and certifications should I include in my business plan?",
    a: "Include EPA Section 608 certification, state contractor's license, local business license, and any manufacturer certifications (Carrier, Trane, etc.). Also mention plans for NATE certification and ongoing training. Licensing costs typically range from $500-$3,000 depending on your state."
  },
  {
    q: "How should I structure my pricing in the business plan?",
    a: "Show three pricing tiers: diagnostic/service calls ($89-$150), repairs ($200-$800 average), and replacements ($4,000-$12,000). Include your markup strategy (typically 40-60% on parts), labor rates ($85-$150/hour), and how you'll handle emergency/after-hours pricing (typically 1.5x standard rates)."
  }
];
