---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: 'processing-rates-comparison', label: 'Processing Rates Comparison' },
  { id: 'jobber-payments', label: 'Jobber Payments Review' },
  { id: 'housecall-pro-payments', label: 'Housecall Pro Payments' },
  { id: 'stripe-square-comparison', label: 'Stripe vs Square for HVAC' },
  { id: 'integration-features', label: 'Integration Features' },
  { id: 'field-payment-solutions', label: 'Field Payment Solutions' },
  { id: 'cost-analysis', label: 'Total Cost Analysis' },
  { id: 'implementation-guide', label: 'Implementation Guide' }
];

const faqItems = [
  { q: "What's the average payment processing rate for HVAC companies?", a: "Most HVAC companies pay between 2.6% and 3.5% per transaction, depending on card type and processing volume. Companies processing over $50,000 monthly typically qualify for lower rates around 2.4-2.9%." },
  { q: "Should I use integrated payments or separate processors?", a: "Integrated payments save 15-20 minutes per invoice and reduce errors by eliminating double data entry. While rates may be 0.1-0.3% higher, the time savings typically justify the cost for teams with 3+ technicians." },
  { q: "Can I accept payments in the field without internet?", a: "Yes, mobile card readers from Square, Stripe Terminal, and integrated solutions like Jobber Payments support offline transactions that sync when connectivity returns. Plan for 1-2% higher offline processing rates." },
  { q: "What payment methods should HVAC companies accept?", a: "Accept Visa, Mastercard, American Express (despite 3.5% rates), Apple Pay, Google Pay, and ACH/bank transfers. Credit cards account for 78% of HVAC payments over $500, with ACH growing for larger commercial jobs." },
  { q: "How do chargebacks affect HVAC payment processing?", a: "HVAC companies average 0.4-0.8% chargeback rates. Processors charge $15-25 per chargeback plus the transaction amount. Integrated systems with photo documentation and digital signatures reduce disputes by 40%." }
];
