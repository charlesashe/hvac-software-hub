                <td style="padding: 12px; border: 1px solid #ddd;"><strong>HCP Payments</strong></td>
                <td style="padding: 12px; border: 1px solid #ddd;">2.5% + $0.15</td>
                <td style="padding: 12px; border: 1px solid #ddd;">3.0% + $0.15</td>
                <td style="padding: 12px; border: 1px solid #ddd;">$0</td>
                <td style="padding: 12px; border: 1px solid #ddd;">Native CRM Integration</td>
              </tr>
              <tr style="background: #f8f9fa;">
                <td style="padding: 12px; border: 1px solid #ddd;"><strong>Square</strong></td>
                <td style="padding: 12px; border: 1px solid #ddd;">2.6% + $0.10</td>
