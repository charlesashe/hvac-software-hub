import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: 'labor-shortage-reality', label: 'The HVAC Labor Shortage Reality' },
  { id: 'compensation-benchmarks', label: '2026 Compensation Benchmarks' },
  { id: 'modern-recruiting-strategies', label: 'Modern Recruiting Strategies' },
  { id: 'training-programs', label: 'Effective Training Programs' },
  { id: 'retention-strategies', label: 'Retention Strategies That Work' },
  { id: 'technology-tools', label: 'Technology Tools for Management' },
  { id: 'measuring-success', label: 'Measuring Management Success' }
];

const faqItems = [
  { q: 'How much should I pay HVAC technicians in 2026?', a: 'Entry-level techs earn $18-22/hour, experienced techs make $26-35/hour, and master techs command $35-45/hour. Add 15-20% in high-cost markets like California or New York.' },
  { q: 'What is the biggest challenge in HVAC hiring right now?', a: 'Finding qualified candidates. 73% of HVAC companies report difficulty filling technician positions, with the average time to fill a tech role now 45 days compared to 28 days in 2020.' },
  { q: 'How can I reduce HVAC employee turnover?', a: 'Focus on competitive pay, clear career paths, quality tools, and flexible scheduling. Companies with structured onboarding see 23% lower turnover in the first year.' },
  { q: 'Should I hire apprentices or experienced techs?', a: 'A mix works best. Aim for 60% experienced techs and 40% apprentices/entry-level. This provides mentorship opportunities while controlling labor costs.' },
  { q: 'What training certifications should I require?', a: 'EPA 608 certification is mandatory. NATE certification adds credibility, and manufacturer-specific training (Carrier, Trane, Lennox) increases service capabilities and margins.' }
];
