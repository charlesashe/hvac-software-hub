---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: 'overview', label: 'HVAC Profit Margin Overview' },
  { id: 'service-type-margins', label: 'Profit Margins by Service Type' },
  { id: 'installation-margins', label: 'Installation Profit Margins' },
  { id: 'repair-margins', label: 'Repair Service Margins' },
  { id: 'maintenance-margins', label: 'Maintenance Contract Margins' },
  { id: 'factors-affecting-margins', label: 'Factors That Impact Your Margins' },
  { id: 'improve-margins', label: 'How to Improve Your Profit Margins' },
  { id: 'tracking-tools', label: 'Tools for Tracking Profitability' }
];

const faqItems = [
  {
    q: "What's a good profit margin for HVAC installation?",
    a: "Healthy HVAC installation margins range from 15-25%. Top performers achieve 30-40% on high-end systems by focusing on value-added services and efficient project management."
  },
  {
    q: "Are HVAC repair margins higher than installation?",
    a: "Yes, repair margins typically run 35-50% compared to 15-25% for installations. Emergency repairs can reach 60-70% margins due to urgency pricing and lower material costs."
  },
  {
    q: "How profitable are HVAC maintenance contracts?",
    a: "Maintenance contracts deliver 40-60% margins with predictable revenue. The key is efficient routing and upselling repairs during scheduled visits."
  },
  {
    q: "What tools help track HVAC profit margins?",
    a: "Job costing software like Jobber, ServiceTitan, or Housecall Pro track materials, labor, and overhead per job. Accurate tracking reveals which services drive the highest margins."
  },
  {
    q: "How often should I review my HVAC pricing?",
    a: "Review pricing quarterly and adjust immediately when material costs change more than 5%. Track competitor pricing monthly and adjust your margins accordingly."
  }
];
---

