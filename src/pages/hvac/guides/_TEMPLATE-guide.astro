<!--
  ArticleLayout Props Reference:
  ┌──────────────┬──────────────────────────────────────────────────────────┐
  │ Prop         │ Description                                            │
  ├──────────────┼──────────────────────────────────────────────────────────┤
  │ title        │ Full <title> tag. Append " — HVAC Software Hub"        │
  │ description  │ Meta description. 150-160 chars. Include primary KW.   │
  │ canonicalPath│ URL path starting with /. Must match file location.    │
  │ category     │ Display label shown in the badge (e.g. "Buyer's Guide")│
  │ publishDate  │ ISO date string (YYYY-MM-DD)                           │
  │ readTime     │ Estimated read time (e.g. "12 min read")               │
  │ intent       │ Funnel stage: "BOFU" | "MOFU" | "TOFU"                 │
  │ heroImage    │ (optional) Full URL to hero image. Omit for text-only. │
  │ tocItems     │ Array of { id, label } for sidebar navigation          │
  │ faqItems     │ Array of { q, a } for FAQ section + JSON-LD schema     │
  └──────────────┴──────────────────────────────────────────────────────────┘
-->
<ArticleLayout
  title="[PLACEHOLDER] Your Article Title (2026) — HVAC Software Hub"
  description="[PLACEHOLDER] A 150-160 character meta description with your primary keyword for HVAC/plumbing contractors."
  canonicalPath="/hvac/guides/[PLACEHOLDER-your-slug]"
  category="Buyer's Guide"
  publishDate="2026-02-17"
  readTime="[PLACEHOLDER] 12 min read"
  intent="MOFU"
  tocItems={tocItems}
  faqItems={faqItems}
>

