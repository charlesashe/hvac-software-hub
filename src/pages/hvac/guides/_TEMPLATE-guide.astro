/**
 * ============================================================
 * HVAC SOFTWARE HUB — GUIDES CATEGORY TEMPLATE
 * ============================================================
 *
 * HOW TO USE THIS TEMPLATE:
 * 1. Copy this file and rename it to your URL slug:
 *    cp _TEMPLATE-guide.astro your-article-slug.astro
 *
 * 2. Replace ALL items marked with [PLACEHOLDER] below.
 *
 * 3. Update the tocItems array to match your actual <h2> sections.
 *    Each { id: "...", label: "..." } must match an id="" attribute
 *    on a section <div> in the body.
 *
 * 4. Update the faqItems array with 3–6 real FAQs. These are used
 *    for both the visible FAQ section AND the FAQPage JSON-LD schema
 *    that Google reads for rich snippets.
 *
 * 5. Delete this comment block before publishing.
 *
 * DESIGN SYSTEM REFERENCE (for this file):
 *   Fonts:    var(--font-heading) = DM Sans | var(--font-body) = Inter | var(--font-mono) = JetBrains Mono
 *   Colors:   var(--color-primary) = accent orange | var(--color-muted) = subdued text
 *   Classes:  .comparison-table | .cta-box | .cta-button | .verdict-strip | .faq-item | .faq-question | .faq-answer | .disclosure-banner
 *   Intent:   MOFU (middle-of-funnel educational content)
 * ============================================================
 */

import ArticleLayout from '../../../layouts/ArticleLayout.astro';

// ── Table of Contents ──────────────────────────────────────
// Each entry becomes a sidebar link. The `id` must match a
// div id="" in the article body below.
const tocItems = [
  { id: "who-is-this-for",    label: "[PLACEHOLDER] Who This Is For" },
  { id: "why-it-matters",     label: "[PLACEHOLDER] Why It Matters" },
  { id: "key-features",       label: "[PLACEHOLDER] Key Features to Evaluate" },
  { id: "comparison",         label: "[PLACEHOLDER] Side-by-Side Comparison" },
  { id: "recommendations",    label: "[PLACEHOLDER] Our Recommendations" },
  { id: "checklist",          label: "[PLACEHOLDER] Evaluation Checklist" },
  { id: "mistakes",           label: "[PLACEHOLDER] Common Mistakes" },
  { id: "faq",                label: "FAQ" }
];

// ── FAQ Items ──────────────────────────────────────────────
// Used for both the visible FAQ section AND the FAQPage
// structured data (JSON-LD) that Google reads for rich results.
// Aim for 3–6 questions. Keep answers under 300 characters for
// best snippet performance.
const faqItems = [
  {
    q: "[PLACEHOLDER] What is the first question your reader would ask?",
    a: "[PLACEHOLDER] Provide a clear, factual answer in 1–3 sentences."
  },
  {
    q: "[PLACEHOLDER] What is the second most common question?",
    a: "[PLACEHOLDER] Answer here."
  },
  {
    q: "[PLACEHOLDER] What is a question that addresses a misconception?",
    a: "[PLACEHOLDER] Correct the misconception clearly."
  },
  {
    q: "[PLACEHOLDER] What is a question about cost or budget?",
    a: "[PLACEHOLDER] Give a realistic range and context."
  },
  {
    q: "[PLACEHOLDER] What is a question about getting started?",
    a: "[PLACEHOLDER] Give a concrete first step."
  }
];
