import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: "why-accounting-matters", label: "Why HVAC Accounting Software Matters" },
  { id: "top-picks-2026", label: "Top 3 HVAC Accounting Software Picks for 2026" },
  { id: "quickbooks-hvac", label: "QuickBooks Online: The Industry Standard" },
  { id: "freshbooks-hvac", label: "FreshBooks: Service-First Approach" },
  { id: "wave-hvac", label: "Wave Accounting: Free Option with Limitations" },
  { id: "feature-comparison", label: "Feature-by-Feature Comparison" },
  { id: "crm-integrations", label: "CRM Integration Capabilities" },
  { id: "pricing-breakdown", label: "Pricing Breakdown and ROI Analysis" },
  { id: "tools-that-pair-well", label: "Tools That Pair Well" }
];

const faqItems = [
  {
    q: "What's the best accounting software for small HVAC companies under 10 employees?",
    a: "QuickBooks Simple Start ($30/month) offers the best balance of features and cost for small HVAC companies. It handles job costing, integrates with major HVAC CRMs like Jobber and HousecallPro, and provides essential financial reporting that most 1-10 person shops need."
  },
  {
    q: "Can I use free accounting software like Wave for my HVAC business?",
    a: "Wave works for very basic bookkeeping but lacks job costing features essential for HVAC profitability tracking. You'll spend $200+ monthly on workarounds (separate project tracking tools, manual reporting) that QuickBooks handles natively for $30-90/month."
  },
  {
    q: "Which accounting software integrates best with ServiceTitan?",
    a: "QuickBooks Online has the most robust ServiceTitan integration, syncing customer data, invoices, and job costs automatically. FreshBooks offers basic integration through Zapier, while Wave requires manual data entry or expensive custom development."
  },
  {
    q: "How much should I budget for HVAC accounting software annually?",
    a: "Plan $360-1,080 annually for accounting software ($30-90/month for QuickBooks tiers). Factor in $100-300 setup costs if you need professional configuration for job costing and CRM integration. The ROI typically pays back within 2-3 months through better job profitability tracking."
  },
  {
    q: "Do I need separate payroll software or can my accounting software handle HVAC payroll?",
    a: "QuickBooks Payroll ($45-125/month) handles HVAC-specific needs like prevailing wage tracking and certified payroll reports. FreshBooks requires third-party payroll integration. For 5+ employees, the integrated approach saves 2-4 hours weekly versus managing separate systems."
  }
];
