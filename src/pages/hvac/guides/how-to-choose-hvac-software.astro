---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: "who-needs", label: "Who Needs This Guide" },
  { id: "categories", label: "Software Categories" },
  { id: "crm-dispatch", label: "CRM & Dispatch" },
  { id: "call-tracking", label: "Call Tracking" },
  { id: "reviews", label: "Review Management" },
  { id: "accounting", label: "Accounting Integration" },
  { id: "stack-by-size", label: "Recommended Stacks by Size" },
  { id: "time-tracking", label: "Time Tracking" },
  { id: "lead-generation", label: "Lead Generation" },
  { id: "evaluation", label: "Evaluation Checklist" },
  { id: "mistakes", label: "Common Mistakes" },
  { id: "faq", label: "FAQ" }
];
const faqItems = [
  { q: "How much should an HVAC company spend on software?", a: "A reasonable benchmark is 1-3% of annual revenue. A $1M/year company should budget $10,000-30,000/year for their full software stack (CRM, accounting, call tracking, reviews). Start with the essentials (CRM + accounting) and add tools as revenue grows." },
  { q: "Should I get an all-in-one platform or best-of-breed tools?", a: "For companies under 10 techs, an all-in-one platform like Jobber or Housecall Pro is usually the better choice — simpler to manage, lower total cost, fewer integrations to maintain. For companies over 15 techs, a best-of-breed approach (ServiceTitan + CallRail + specialized tools) often provides better depth in each category." },
  { q: "What is the most important software for a new HVAC company?", a: "Start with a CRM/field service platform (Jobber or Housecall Pro) and QuickBooks. These two tools handle 80% of your operational needs: scheduling, dispatching, invoicing, and accounting. Add call tracking and review management once you start spending on marketing." },
  { q: "How do I migrate from one platform to another?", a: "Most platforms support CSV data export. The typical migration process is: (1) export customer and job data from old platform, (2) clean the data in a spreadsheet, (3) import into new platform, (4) run both platforms in parallel for 1-2 weeks, (5) fully switch over. Budget 1-4 weeks depending on complexity." },
  { q: "Do I need separate software for commercial vs residential work?", a: "If commercial work is less than 20% of your revenue, your residential CRM can usually handle it. If commercial is a significant part of your business, consider platforms that handle both well (ServiceTitan, FieldEdge, BuildOps) or run separate systems for each division." }
];
