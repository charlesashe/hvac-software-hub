---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

const tocItems = [
  { id: "fit-score", label: "Dispatch Fit Score" },
  { id: "quick-pick", label: "Quick Pick Table" },
  { id: "servicetitan", label: "1. ServiceTitan" },
  { id: "workiz", label: "2. Workiz" },
  { id: "jobber", label: "3. Jobber" },
  { id: "service-fusion", label: "4. Service Fusion" },
  { id: "decision-tree", label: "How to Choose" },
  { id: "faq", label: "FAQ" }
];
const faqItems = [
  { q: "Do I need separate dispatch software or is my CRM enough?", a: "Most modern CRMs include dispatch features. If your CRM's dispatch board handles your volume, you don't need a separate tool. Consider dedicated dispatch features if you have 5+ techs running 15+ jobs per day." },
  { q: "What is route optimization and do I need it?", a: "Route optimization automatically sequences jobs to minimize drive time. If your techs cover a large service area or run 4+ jobs per day, route optimization can save 30-60 minutes per tech per day in windshield time." },
  { q: "Can dispatch software reduce my fuel costs?", a: "Yes. Route optimization and GPS tracking typically reduce fuel costs by 10-20% by eliminating unnecessary driving. For a 5-truck fleet, that can mean $500-$1,000/mo in savings." },
  { q: "How does real-time GPS tracking help my dispatch?", a: "GPS tracking lets your dispatcher see where every tech is in real time. This means you can assign emergency calls to the nearest available tech instead of guessing, reducing response times and improving customer satisfaction." }
];
