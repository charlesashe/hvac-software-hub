  { id: "comparison-table", label: "Comparison Table" },
  { id: "traditional", label: "Best Traditional Services" },
  { id: "virtual-receptionist", label: "Best Virtual Receptionists" },
  { id: "ai-voice-agents", label: "Best AI Voice Agents" },
  { id: "why-ai-wins", label: "Why AI Is Winning for HVAC" },
  { id: "how-to-choose", label: "How to Choose" },
  { id: "faq", label: "FAQ" }
];
const faqItems = [
  { q: "How much does an HVAC answering service cost?", a: "Traditional services run $150-$500/mo plus per-minute overages. Virtual receptionists run $300-$800/mo. AI voice agents run $83-$1,250/mo depending on whether you self-manage the platform or use a managed service. See our full HVAC answering service pricing guide for detailed breakdowns." },
  { q: "Can an AI really handle HVAC emergency calls?", a: "Yes. Platforms like Thinkrr AI use conversational AI that asks qualifying questions, determines urgency, and can transfer the call live to your on-call tech within seconds. The AI is configured with your specific emergency protocols, so it knows your on-call schedule, service area, and escalation rules." },
  { q: "What happens if the AI cannot handle a call?", a: "The best AI platforms have live transfer capability. If the AI encounters a scenario it cannot handle, it transfers the caller to your team with full context: who is calling, what they said, and what the issue is. On Thinkrr-based systems, this transfer happens seamlessly mid-call." },
  { q: "Do I still need a receptionist if I get an answering service?", a: "Many HVAC companies use AI for after-hours, weekends, and overflow during peak season. Some smaller companies replace their receptionist entirely and use the built-in CRM that comes with platforms like Thinkrr to manage their entire lead flow. That saves $3,000-$5,000/month in salary while improving response time." },
  { q: "Which answering service integrates with ServiceTitan?", a: "AnswerForce has direct integration. Smith.ai connects via Zapier. Thinkrr-based services like Meridian Gable connect to ServiceTitan, Housecall Pro, and Jobber via webhooks and Zapier, with native GoHighLevel support." }
];
