---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  category: string;
  publishDate: string;
  readTime: string;
  intent: string;
  heroImage?: string;
  tocItems?: { id: string; label: string }[];
  faqItems?: { q: string; a: string }[];
}

const { title, description, canonicalPath, category, publishDate, readTime, intent, heroImage, tocItems = [], faqItems = [] } = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  <!-- Hero -->
  {heroImage && (
    <div class="relative h-64 md:h-80 overflow-hidden">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 container pb-8">
        <div class="flex items-center gap-2 mb-3">
          <span class="data-label bg-white/20 text-white px-2 py-0.5 rounded text-xs backdrop-blur-sm">{category}</span>
          <span class="data-label text-white/80 text-xs">{intent}</span>
        </div>
        <h1 class="text-2xl md:text-4xl font-bold text-white leading-tight" style="font-family: var(--font-heading);">{title.replace(/ — .*$/, '').replace(/ \(2026\)$/, '')}</h1>
      </div>
    </div>
  )}

  <div class="container py-8">
    <div class="flex gap-12">
      <!-- Article Content -->
      <article class="flex-1 min-w-0 max-w-3xl prose">
        {!heroImage && (
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="data-label bg-[var(--color-accent)] px-2 py-0.5 rounded text-xs">{category}</span>
              <span class="data-label text-xs">{intent}</span>
            </div>
            <h1 class="text-2xl md:text-4xl font-bold leading-tight" style="font-family: var(--font-heading);">{title.replace(/ — .*$/, '').replace(/ \(2026\)$/, '')}</h1>
          </div>
        )}

        <!-- Author & Date -->
        <div class="flex items-center gap-3 text-sm text-[var(--color-muted)] mb-4">
          <span>{readTime}</span>
          <span>&middot;</span>
          <span>Published {formattedDate}</span>
        </div>

        <!-- Disclosure Banner -->
        <div class="disclosure-banner">
          <strong>Affiliate Disclosure:</strong> Some links in this article are affiliate links. If you click through and make a purchase, we may earn a commission at no additional cost to you. We only recommend products we have evaluated. <a href="/disclosure" class="underline">Full disclosure</a>.
        </div>

        <!-- Article Body -->
        <slot />

        <!-- Author Byline -->
        <div class="mt-10 pt-6 border-t border-[var(--color-border)]">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0">
              <span class="text-[var(--color-primary)] font-bold" style="font-family: var(--font-mono);">HS</span>
            </div>
            <div>
              <p class="font-semibold text-sm" style="font-family: var(--font-heading);">HVAC Software Hub Editorial Team</p>
              <p class="text-xs text-[var(--color-muted)] mt-1 leading-relaxed">
                Our team researches, tests, and scores software tools using a transparent methodology built specifically for HVAC and plumbing businesses. Every recommendation is based on hands-on evaluation, not paid placement.
              </p>
            </div>
          </div>
        </div>
      </article>

      <!-- Sidebar TOC -->
      {tocItems.length > 0 && (
        <aside class="hidden lg:block w-64 flex-shrink-0">
          <div class="sticky top-24">
            <h4 class="data-label mb-3">On This Page</h4>
            <nav class="space-y-1">
              {tocItems.map((item) => (
                <a href={`#${item.id}`} class="block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] no-underline py-1 transition-colors">
                  {item.label}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>

  <!-- FAQ Schema -->
  {faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />
  )}
</Layout>
