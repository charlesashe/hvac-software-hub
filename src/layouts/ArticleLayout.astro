---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  category: string;
  publishDate: string;
  readTime: string;
  intent: string;
  heroImage?: string;
  tocItems?: { id: string; label: string }[];
  faqItems?: { q: string; a: string }[];
}

const { title, description, canonicalPath, category, publishDate, readTime, intent, heroImage, tocItems = [], faqItems = [] } = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  <!-- Hero -->
  {heroImage && (
    <div class="relative h-64 md:h-80 overflow-hidden">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 container pb-8">
        <div class="flex items-center gap-2 mb-3">
          <span class="data-label bg-white/20 text-white px-2 py-0.5 rounded text-xs backdrop-blur-sm">{category}</span>
          <span class="data-label text-white/80 text-xs">{intent}</span>
        </div>
        <h1 class="text-2xl md:text-4xl font-bold text-white leading-tight" style="font-family: var(--font-heading);">{title.replace(/ — .*$/, '').replace(/ \(2026\)$/, '')}</h1>
      </div>
    </div>
  )}

  <div class="container py-8">
    <div class="flex gap-12">
      <!-- Article Content -->
      <article class="flex-1 min-w-0 max-w-3xl prose">
        {!heroImage && (
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="data-label bg-[var(--color-accent)] px-2 py-0.5 rounded text-xs">{category}</span>
              <span class="data-label text-xs">{intent}</span>
            </div>
            <h1 class="text-2xl md:text-4xl font-bold leading-tight" style="font-family: var(--font-heading);">{title.replace(/ — .*$/, '').replace(/ \(2026\)$/, '')}</h1>
          </div>
        )}

        <!-- Author & Date -->
        <div class="flex items-center gap-3 text-sm text-[var(--color-muted)] mb-4">
          <span>{readTime}</span>
          <span>&middot;</span>
          <span>Published {formattedDate}</span>
        </div>

        <!-- Disclosure Banner -->
        <div class="disclosure-banner">
          <strong>Affiliate Disclosure:</strong> Some links in this article are affiliate links. If you click through and make a purchase, we may earn a commission at no additional cost to you. We only recommend products we have evaluated. <a href="/disclosure" class="underline">Full disclosure</a>.
        </div>

        <!-- Article Body -->
        <slot />

        <!-- CTA Block A: In-article consulting CTA (after main content, before author byline) -->
        <div style="background: #f0f7ff; border-left: 4px solid #1B4F72; padding: 20px 24px; margin: 32px 0; border-radius: 0 8px 8px 0;">
          <p style="font-weight: 700; font-size: 18px; margin: 0 0 8px 0; color: #1B4F72;">Not sure which tool fits your operation?</p>
          <p style="margin: 0 0 12px 0; color: #333; font-size: 15px;">We help HVAC shops in the Carolinas connect their tools so leads stop falling through the cracks. Get a free 15-minute diagnostic — no pitch, just data you can use.</p>
          <a href="https://calendly.com/meridiangable/free-hvac-audit?utm_source=hvacsoftwarehub&utm_medium=in-content-cta&utm_campaign=service-routing" style="display: inline-block; background: #1B4F72; color: #fff; padding: 10px 24px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 15px;">Book Free Audit</a>
        </div>

        <!-- Author Byline -->
        <div class="mt-10 pt-6 border-t border-[var(--color-border)]">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0">
              <span class="text-[var(--color-primary)] font-bold" style="font-family: var(--font-mono);">HS</span>
            </div>
            <div>
              <p class="font-semibold text-sm" style="font-family: var(--font-heading);">HVAC Software Hub Editorial Team</p>
              <p class="text-xs text-[var(--color-muted)] mt-1 leading-relaxed">
                Our team researches, tests, and scores software tools using a transparent methodology built specifically for HVAC and plumbing businesses. Every recommendation is based on hands-on evaluation, not paid placement.
              </p>
            </div>
          </div>
        </div>

        <!-- ConvertKit Email Opt-in: HVAC Lead Magnet (Form ID: 9150571) -->
        <div style="margin: 40px 0; padding: 28px 24px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; text-align: center;">
          <p style="font-weight: 700; font-size: 17px; margin: 0 0 6px 0; color: #1B4F72;">Get the HVAC Software Buyer's Checklist</p>
          <p style="font-size: 14px; color: #555; margin: 0 0 16px 0;">Free guide: the 7 questions every HVAC contractor should ask before buying software. Delivered to your inbox.</p>
          <script async data-uid="4dc75959ff" src="https://meridian-gable-corporation.kit.com/4dc75959ff/index.js"></script>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24 space-y-6">
          <!-- Sidebar TOC -->
          {tocItems.length > 0 && (
            <div>
              <h4 class="data-label mb-3">On This Page</h4>
              <nav class="space-y-1">
                {tocItems.map((item) => (
                  <a href={`#${item.id}`} class="block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] no-underline py-1 transition-colors">
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- CTA Block B: Sidebar persistent consulting CTA -->
          <div style="background: #1B4F72; color: #fff; padding: 24px; border-radius: 8px; text-align: center;">
            <p style="font-weight: 700; font-size: 16px; margin: 0 0 8px 0;">Losing leads to slow follow-up?</p>
            <p style="font-size: 14px; margin: 0 0 12px 0; opacity: 0.9;">Free 15-min HVAC audit. We show you where leads drop off.</p>
            <a href="https://calendly.com/meridiangable/free-hvac-audit?utm_source=hvacsoftwarehub&utm_medium=sidebar-cta&utm_campaign=service-routing" style="display: inline-block; background: #fff; color: #1B4F72; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px;">Book Audit</a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- FAQ Schema -->
  {faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />
  )}

  <!-- Affiliate click event tracking (GA4) -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('a[href*="getjobber"], a[href*="servicefusion"], a[href*="apollo.io"], a[href*="toggl"], a[href*="servicetitan"], a[data-affiliate]').forEach(function(link) {
        link.addEventListener('click', function() {
          if (typeof gtag === 'function') {
            gtag('event', 'affiliate_click', {
              'vendor': this.dataset.vendor || this.href.match(/getjobber|servicefusion|apollo|toggl|servicetitan|callrail/i)?.[0] || 'unknown',
              'article': document.title,
              'position': this.dataset.position || 'body'
            });
          }
        });
      });
    });
  </script>
</Layout>
